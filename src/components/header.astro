---
import { siteMeta } from "@lib/constants";
import { Button } from "@components/ui/button";
import { Menu } from "@lucide/astro";
import { cn } from "@/lib/utils";

interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<header
  class:list={[
    "grid grid-cols-[auto_1fr] grid-flow-col gap-2 justify-start items-center px-2 py-2",
    className,
  ]}
>
  <Button
    id="menu-toggle"
    className={cn(
      "bg-transparent text-inherit rounded-full cursor-pointer py-6 px-4",
      "hover:bg-gray-200",
    )}
  >
    <Menu />
  </Button>

  <div
    class:list={[
      "font-bold text-lg",
      "group-[.is-toggled]:hidden",
      "md:group-[.is-toggled]:block",
    ]}
  >
    <a href="/">{siteMeta.siteTitle}</a>
  </div>
</header>

<script>
  const menuButton = document.getElementById("menu-toggle");

  menuButton?.addEventListener("click", () => {
    document.querySelector(".dashboard")?.classList.toggle("is-toggled");
  });
</script>
