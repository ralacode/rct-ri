---
import Layout from "@layouts/layout.astro";
import { PatientEdit } from "@components/react/patient/edit";

const { patient_id } = Astro.params;

if (!patient_id) {
  return Astro.redirect("/patient/list/");
}

export const prerender = false;
---

<Layout>
  <PatientEdit client:load patientId={patient_id} />
</Layout>
