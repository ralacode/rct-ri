---
// src/pages/patient/[patient_id]/index.astro

import Layout from "@layouts/layout.astro";
import { PatientDetail } from "@components/react/patient/detail";

export function getStaticPaths() {
  // 開発中やビルド時は空、もしくはサンプルのIDを返します。
  // Tauriの実際の動作には影響しません（client:loadでReact側が動くため）。
  return [{ params: { patient_id: "default" } }];
}

const { patient_id } = Astro.params;
---

<Layout>
  <PatientDetail client:load />
  <a href={`/patient/${patient_id}/edit/`}>編集する</a>
  <a href="/patient/list/">患者一覧</a>
</Layout>
